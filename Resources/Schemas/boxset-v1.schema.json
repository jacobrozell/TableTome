{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tabletome.app/schemas/boxset-v1.schema.json",
  "title": "Tabletome Box Sets v1",
  "description": "Featured starter box sets for a game system. Replaces the hardcoded FeaturedArmiesConfig in GameSystemId+Bundled.swift (Phase 4). Adding a box set = one object here + green content-lint, zero Swift.",
  "type": "object",
  "required": ["schemaVersion", "gameSystemId", "boxSets"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "gameSystemId": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "boxSets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/boxSet" }
    }
  },
  "definitions": {
    "boxSet": {
      "type": "object",
      "required": ["id", "starterMatchupTitle", "playerOne", "playerTwo"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "starterMatchupTitle": { "type": "string", "minLength": 1 },
        "starterSetDescription": { "type": "string" },
        "starterSetBadge": { "type": "string" },
        "defaultMissionId": { "type": "string" },
        "armyIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "playerOne": { "$ref": "#/definitions/starterArmySelection" },
        "playerTwo": { "$ref": "#/definitions/starterArmySelection" }
      }
    },
    "starterArmySelection": {
      "type": "object",
      "required": ["factionId", "armyId"],
      "additionalProperties": true,
      "properties": {
        "playerName": { "type": "string" },
        "factionId": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "armyId": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
      }
    }
  }
}
