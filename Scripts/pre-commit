#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

PATTERNS=(
  'GoogleService-Info\.plist'
  'Secrets\.plist'
  '\.env(\.|$)'
  'credentials\.json'
  '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
  'AIza[0-9A-Za-z_-]{35}'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)

for file in $STAGED; do
  for pattern in "${PATTERNS[@]}"; do
    if [[ "$file" =~ $pattern ]] || grep -qE "$pattern" "$file" 2>/dev/null; then
      echo "pre-commit: blocked — possible secret in $file (pattern: $pattern)"
      exit 1
    fi
  done
done

# Content lint — validate bundled game content when any of it changed.
if echo "$STAGED" | grep -qE '^Resources/(Rules|Schemas)/'; then
  if command -v python3 >/dev/null 2>&1; then
    python3 Scripts/validate_content.py --quiet || {
      echo "pre-commit: blocked — content-lint failed (see above)."
      exit 1
    }
  fi
fi

# Architecture-debt ratchet — block re-introduction of removed anti-patterns
# when Swift sources changed.
if echo "$STAGED" | grep -qE '\.swift$'; then
  Scripts/check_architecture_debt.sh || {
    echo "pre-commit: blocked — architecture-debt budget exceeded (see above)."
    exit 1
  }
fi

exit 0
